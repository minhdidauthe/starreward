# Star Reward Application Configuration

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/star_reward_app

# Session Secret
SESSION_SECRET=your-secret-key-here

# RapidAPI Configuration (for Reddit Meme crawler)
RAPIDAPI_KEY=your-rapidapi-key-here

# Reddit OAuth API (Optional - for direct Reddit integration)
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REFRESH_TOKEN=your-refresh-token
REDDIT_USER_AGENT=StarReward/1.0

# CLIProxy Configuration (for AI models)
# CLIProxy is a unified API proxy for Gemini, ChatGPT, Claude
CLIPROXY_URL=http://localhost:5000
CLIPROXY_API_KEY=your-cliproxy-api-key

# Alternative: Direct AI API Keys (if not using CLIProxy)
# Gemini
GEMINI_API_KEY=your-gemini-api-key

# ChatGPT
OPENAI_API_KEY=your-openai-api-key

# Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# File Upload (Optional - for future image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
